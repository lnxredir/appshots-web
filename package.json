{
  "name": "appshots-web",
  "version": "0.2.4",
  "description": "Generate App Store-ready screenshots in your browser — frame, style, and export with a self-hosted web studio.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "appshots": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "ui": "npm run dev --prefix ui",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "app-store",
    "screenshots",
    "playwright",
    "ios",
    "android",
    "google-play",
    "app-store-connect",
    "screenshot-generator",
    "cli",
    "mobile",
    "sharp"
  ],
  "author": "Albert Nahas",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lnxredir/appshots-web.git"
  },
  "homepage": "https://github.com/lnxredir/appshots-web#readme",
  "bugs": {
    "url": "https://github.com/lnxredir/appshots-web/issues"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^13.1.0",
    "ora": "^8.2.0",
    "sharp": "^0.33.5",
    "zod": "^3.24.2"
  },
  "peerDependencies": {
    "playwright": "^1.49.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18"
  }
}
